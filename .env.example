# Copie para .env e preencha. NUNCA suba o .env pro GitHub.

PORT=3333

# URL pública (mesmo domínio que serve o site)
FRONTEND_URL=https://seudominio.com
BACKEND_URL=https://seudominio.com

# Preço do álbum
PRECO_ALBUM=29.90

# Mercado Pago — Access Token de PRODUÇÃO (Suas integrações > Credenciais)
MP_ACCESS_TOKEN=APP_USR-xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx

# E-mail (SMTP) — envia o link de download após o pagamento. OPCIONAL.
SMTP_HOST=smtp.hostinger.com
SMTP_PORT=465
SMTP_SECURE=1
SMTP_USER=seu-email@seudominio.com
SMTP_PASS=sua-senha
SMTP_FROM=seu-email@seudominio.com
